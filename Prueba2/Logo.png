
    <html xmlns:o="urn:schemas-microsoft-com:office:office"
          xmlns:w="urn:schemas-microsoft-com:office:word"
          xmlns="http://www.w3.org/TR/REC-html40">
      <head>
        <meta charset="utf-8">
        <title>Evaluación del desempeño</title>
        <style>
          body{font-family:Arial,sans-serif;color:#000;padding:18px}
          .ie-wrap,.ie-card,.ie-cell,.ie-block{box-sizing:border-box}
          .ie-card{border:1px solid #d1d5db;border-radius:12px;padding:14px;background:#fff}
          .ie-title{font-size:18px;font-weight:700;margin-bottom:8px}
          .ie-sub{font-size:12px;color:#444;margin-bottom:12px}
          .ie-grid{width:100%;margin:10px 0}
          .ie-cell,.ie-block{border:1px solid #d1d5db;border-radius:10px;padding:10px;margin-bottom:10px}
          .ie-k{font-size:12px;font-weight:700;margin-bottom:4px}
          .ie-v{font-size:13px}
          .ie-pre{white-space:pre-wrap}
          .ie-score .ie-v{font-size:18px;font-weight:700}
        </style>
      </head>
            <body>
        
        <div class="ie-wrap">
          <style>
            .evalrep{font-family:var(--sans);color:var(--text)}
            .evalrep .box{border:1px solid rgba(255,255,255,.10);border-radius:16px;padding:14px;background:rgba(11,18,32,.22);margin-bottom:12px}
            .evalrep h2{margin:0 0 12px 0;font-size:20px}
            .evalrep table{width:100%;border-collapse:separate;border-spacing:0}
            .evalrep thead th{background:rgba(15,27,51,.95);padding:10px;text-align:left;border-bottom:1px solid rgba(255,255,255,.10);white-space:nowrap}
            .evalrep tbody td{padding:10px;border-bottom:1px solid rgba(255,255,255,.06);vertical-align:top}
            .grid3{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
            .cell{border:1px solid rgba(255,255,255,.10);border-radius:14px;padding:12px;background:rgba(11,18,32,.18)}
            .k{font-weight:800;margin-bottom:6px}
            .v{white-space:pre-wrap}
          </style>

          <div class="evalrep">
            <div class="box">
              <h2>Reporte de evaluación del desempeño</h2>

              <div class="grid3" style="margin-bottom:12px">
                <div class="cell"><div class="k">No. de personal</div><div class="v">1201</div></div>
                <div class="cell"><div class="k">Nombre</div><div class="v">Eduardo Alfredo Caastillo</div></div>
                <div class="cell"><div class="k">Posición</div><div class="v">Asistente Administrativo</div></div>
                <div class="cell"><div class="k">Departamento</div><div class="v">Ventas</div></div>
                <div class="cell"><div class="k">Versión</div><div class="v">1</div></div>
                <div class="cell"><div class="k">Fecha</div><div class="v">24/04/2026</div></div>
                <div class="cell"><div class="k">Puntaje final</div><div class="v">57.00</div></div>
              </div>

              <div class="tableWrap" style="margin-bottom:12px">
                <table>
                  <thead>
                    <tr>
  </tr><tr>
  <th style="width:45ch;max-width:45ch">Ítem</th>
  <th>Respuesta</th>
</tr>
                  </thead>
                  <tbody>
        <tr>
          <td>1. Cumplimiento de Resultados</td>
<td>3 — Cumple objetivos en tiempo estándar KPI: 76-90%</td>
        </tr>
      
        <tr>
          <td>2. Gestión Documental</td>
<td>3 — Control adecuado KPI: ≤5% errores</td>
        </tr>
      
        <tr>
          <td>3. Calidad de Información</td>
<td>3 — Información correcta KPI: ≤5%</td>
        </tr>
      
        <tr>
          <td>4. Gestión del Tiempo</td>
<td>3 — Cumple plazos KPI: ≤10%</td>
        </tr>
      
        <tr>
          <td>5. Atención al Cliente Interno/Externo</td>
<td>3 — Atención adecuada KPI: &lt;12h</td>
        </tr>
      
        <tr>
          <td>6. Seguimiento de Procesos</td>
<td>3 — Seguimiento adecuado KPI: ≤10%</td>
        </tr>
      
        <tr>
          <td>7. Orden y Organización</td>
<td>2 — Organización deficiente KPI: 10-20%</td>
        </tr>
      
        <tr>
          <td>8. Comunicación Efectiva</td>
<td>3 — Comunicación clara KPI: ≤10%</td>
        </tr>
      
        <tr>
          <td>9. Proactividad</td>
<td>3 — Cumple tareas KPI: 3-4 iniciativas</td>
        </tr>
      
        <tr>
          <td>10. Trabajo en Equipo</td>
<td>3 — Trabajo colaborativo KPI: 1-2</td>
        </tr>
      
        <tr>
          <td>11. Confiabilidad</td>
<td>2 — Inconsistente KPI: 10-15%</td>
        </tr>
      
        <tr>
          <td>12. Responsabilidad</td>
<td>2 — Cumple parcialmente KPI: 10-15%</td>
        </tr>
      
        <tr>
          <td>13. Integridad</td>
<td>3 — Cumple normas KPI: 1 alerta</td>
        </tr>
      
        <tr>
          <td>14. Manejo de Herramientas</td>
<td>3 — Uso adecuado KPI: ≤10%</td>
        </tr>
      
        <tr>
          <td>15. Gestión de Agenda</td>
<td>3 — Coordinación adecuada KPI: ≤10%</td>
        </tr>
      
        <tr>
          <td>16. Soporte Administrativo</td>
<td>3 — Apoyo adecuado KPI: ≤10%</td>
        </tr>
      
        <tr>
          <td>17. Gestión de Proveedores</td>
<td>3 — Gestión adecuada KPI: ≤10%</td>
        </tr>
      
        <tr>
          <td>18. Control de Recursos</td>
<td>3 — Uso adecuado KPI: ≤10%</td>
        </tr>
      
        <tr>
          <td>19. Adaptabilidad</td>
<td>3 — Adaptación funcional KPI: impacto bajo</td>
        </tr>
      
        <tr>
          <td>20. Mejora Continua</td>
<td>3 — Mejora ocasional KPI: 3-4</td>
        </tr>
      </tbody>
                </table>
              </div>

              <div class="grid1">
  <div class="cell"><div class="k">Justificación y comentarios</div><div class="v">He hecho un buen trabajo,</div></div>
  <div class="cell"><div class="k">Comentarios del colaborador</div><div class="v">Requiero capacitación en excel, elaboración de planillas</div></div>
  <div class="cell"><div class="k">Comentarios del evaluador</div><div class="v">Eduardo es buen colaborador</div></div>
  <div class="cell"><div class="k">Fortalezas</div><div class="v">matematicas financiera</div></div>
  <div class="cell"><div class="k">Oportunidades de mejora</div><div class="v">Puede mejorar su forma de manejar las cosas</div></div>
  <div class="cell"><div class="k">Proyección y potencial de desarrollo</div><div class="v">Puede ser ascendido a otras possiciones</div></div>
  <div class="cell"><div class="k">Necesidades de capacitación</div><div class="v">Excel, power point, diseño de planillas</div></div>
  <div class="firmas">
    <span class="firma">Firma del evaluado</span><span class="sep18"></span><span class="firma">Firma del evaluador</span>
  </div>
</div>
            </div>
          </div>
        </div>
      
        <br><br><br><br><br><br><br><br><br><br>

        <div style="width:100%; text-align:center; font-weight:700; white-space:nowrap;">
          Firma del evaluado&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Firma del evaluador
        </div>
        
      </body>
    </html>
  
